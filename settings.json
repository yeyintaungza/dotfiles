{
  "workbench.sideBar.location": "right",
  "editor.minimap.enabled": false,
  "editor.lineNumbers": "relative",
  "editor.lineHeight": 1.8,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": false,
  "workbench.settings.applyToAllProfiles": [],
  "vim.showMarksInGutter": true,
  "vim.foldfix": true,
  "vim.surround": true,
  "vim.easymotion": true,
  "vim.easymotionKeys": "asdghklqwertyuiopzxcvbnmfj",
  "vim.leader": "<space>",
  "vim.insertModeKeyBindings": [
    {
      "before": [
        "j",
        "k"
      ],
      "after": [
        "<Esc>"
      ]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "s"
      ],
      "commands": [
        "flash-vscode.start"
      ]
    },
    {
      "before": [
        "<leader>",
        "s",
        "d"
      ],
      "commands": [
        "workbench.panel.markers.view.focus"
      ]
    },
    {
      "before": [
        "S"
      ],
      "commands": [
        "flash-vscode.startSelection"
      ]
    },
    {
      "before": [
        "<BS>"
      ],
      "commands": [
        "flash-vscode.backspace"
      ]
    },
    {
      "before": [
        "<leader>",
        "b",
        "o"
      ],
      "commands": [
        "workbench.action.closeOtherEditors"
      ]
    },
    {
      "before": [
        "<leader>",
        "b",
        "d"
      ],
      "commands": [
        "workbench.action.closeActiveEditor"
      ]
    },
    {
      "before": [
        ":",
        "w",
        "<CR>"
      ],
      "commands": [
        "workbench.action.files.save"
      ]
    },
    {
      "before": [
        "<leader>",
        "w"
      ],
      "commands": [
        "workbench.action.files.save"
      ]
    },
    {
      "before": [
        "<leader>",
        "q"
      ],
      "commands": [
        "workbench.action.closeWindow"
      ],
      "when": "workbench.action.closeWindow"
    },
    {
      "before": [
        "<leader>",
        "f"
      ],
      "commands": [
        "code-telescope.fuzzy.file"
      ]
    },
    // code-telescope.fuzzy.file
  ],
  "vim.normalModeKeyBindings": [
    {
      "before": [
        "<C-h>"
      ],
      "after": [
        "<C-W>",
        "h"
      ]
    },
    {
      "before": [
        "<C-j>"
      ],
      "after": [
        "<C-W>",
        "j"
      ]
    },
    {
      "before": [
        "<C-k>"
      ],
      "after": [
        "<C-W>",
        "k"
      ]
    },
    {
      "before": [
        "<C-l>"
      ],
      "after": [
        "<C-W>",
        "l"
      ]
    },
    {
      "before": [
        "<S-h>"
      ],
      "commands": [
        ":bprev"
      ]
    },
    {
      "before": [
        "<S-l>"
      ],
      "commands": [
        ":bnext"
      ]
    },
    {
      "before": [
        "g",
        "d"
      ],
      "commands": [
        "editor.action.revealDefinition"
      ]
    },
    {
      "before": [
        "g",
        "r"
      ],
      "commands": [
        "editor.action.goToReferences"
      ]
    },
    {
      "before": [
        "g",
        "D"
      ],
      "commands": [
        "editor.action.revealDeclaration"
      ]
    },
    {
      "before": [
        "g",
        "I"
      ],
      "commands": [
        "editor.action.goToImplementation"
      ]
    },
    {
      "before": [
        "g",
        "y"
      ],
      "commands": [
        "editor.action.goToTypeDefinition"
      ]
    },
    {
      "before": [
        "K"
      ],
      "commands": [
        "editor.action.showDefinitionPreviewHover"
      ]
    },
    {
      "before": [
        "<leader>",
        "c",
        "a"
      ],
      "commands": [
        "editor.action.quickFix"
      ],
      "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
    },
    {
      "before": [
        "<leader>",
        "c",
        "r"
      ],
      "commands": [
        "editor.action.rename"
      ],
      "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
    },
    {
      "before": [
        "<leader>",
        "e"
      ],
      "commands": [
        "workbench.action.toggleSidebarVisibility"
      ]
    },
    {
      "before": [
        "<leader>",
        "E"
      ],
      "commands": [
        "workbench.explorer.fileView.toggleVisibility"
      ]
    },
    {
      "before": [
        "<leader>",
        "<space>"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "b"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "f"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "F"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "r"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "f",
        "R"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "<leader>",
        "u",
        "C"
      ],
      "commands": [
        "workbench.action.selectTheme"
      ]
    }
  ],
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [],
    "editor.selectionHighlight": false,
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off"
  },
  "editor.indentSize": "tabSize",
  "workbench.tree.indent": 12,
  "editor.fontFamily": "JetBrainsMono Nerd Font,JetBrains Mono",
  "editor.inlayHints.enabled": "off",
  "dart.previewFlutterUiGuides": true,
  "dart.previewFlutterUiGuidesCustomTracking": true,
  "vim.useSystemClipboard": true,
  "editor.foldingImportsByDefault": true,
  "git.openRepositoryInParentFolders": "never",
  "workbench.activityBar.location": "hidden",
  "workbench.colorCustomizations": {
    // these are for mono chrome theme
    // "editorComments.foreground": "#8f8f8f",
    // "tab.activeBorderTop": "#00aaaa",
    // Better gutter visibility
    //"editorGutter.background": "#111111",
    // Relative line numbers
    // "editorLineNumber.foreground": "#5a5a5a",
    // "editorLineNumber.activeForeground": "#ffffff",
    "statusBar.background": "#005f5f",
    "statusBar.noFolderBackground": "#005f5f",
    "statusBar.debuggingBackground": "#005f5f",
    "statusBar.foreground": "#ffffff",
    "statusBar.debuggingForeground": "#ffffff",
    // Vim navigation focus
    "editor.lineHighlightBackground": "#1c1c1c",
    "editor.lineHighlightBorder": "#2a2a2a",
    // Git/vim marks
    "editorGutter.modifiedBackground": "#888888",
    "editorGutter.addedBackground": "#bbbbbb",
    "editorGutter.deletedBackground": "#666666"
  },
  "window.commandCenter": false,
  "workbench.startupEditor": "none",
  "terminal.integrated.stickyScroll.enabled": false,
  "workbench.browser.showInTitleBar": false,
  "workbench.layoutControl.enabled": false,
  "terminal.integrated.localEchoExcludePrograms": [
    "vim",
    "vi"
  ],
  "terminal.integrated.defaultLocation": "editor",
  "ollama.autocomplete.enabled": false,
  "workbench.iconTheme": "symbols",
  "ollama.saasUrl": "https://ai-agent.za.net.mm",
  "ollama.model": "qwen3.6:35b",
  "workbench.colorTheme": "Kanagawa"
}
