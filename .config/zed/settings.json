{
  "project_panel": {
    "dock": "right"
  },
  "theme": "Kanagawa",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font",

  "relative_line_numbers": true,
  "show_minimap": false,

  "tab_size": 2,
  "hard_tabs": false,

  "vim_mode": true,

  "cursor_blink": true,

  "indent_guides": {
    "enabled": true
  },

  "preferred_line_length": 100,

  "soft_wrap": "none",

  "show_whitespaces": "none",

  "git": {
    "inline_blame": false
  }
}
